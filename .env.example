# SALMAN OS v1 data source policy:
# - mock: default and only active local adapter for the internal MVP.
# - supabase: reserved for explicit local-only activation tests.
# - missing or invalid values fall back to mock.
VITE_DATA_SOURCE=mock
VITE_SUPABASE_READ_ACTIVATION=off

# Supabase browser client placeholders.
# Do not put service_role keys in any Vite frontend env file.
# Put real values only in a local, uncommitted env file after explicit approval.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ENV=local

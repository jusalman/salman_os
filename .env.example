# SALMAN OS v1 data source policy:
# - mock: default and only active local adapter for the internal MVP.
# - supabase: reserved placeholder; no Supabase connection is implemented yet.
# - missing or invalid values fall back to mock.
VITE_DATA_SOURCE=mock

# Reserved for a future Supabase read adapter. Do not put real keys in this file.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ENV=local
